# Copy to env.smmbench.local and fill in secrets.
# Usage: source scripts/env.smmbench.local && bash scripts/run_omnisimplemem_local.sh

# Resolve Absolute paths to this SimpleMem checkout.
SMMBENCH_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
REPO_ROOT="$(cd "${SMMBENCH_ROOT}/../../.." && pwd)"

export DATASET_PARENT_DIR="${SMMBENCH_ROOT}/data/Samples"
export IMAGE_ROOT_DIR="${SMMBENCH_ROOT}/data/Images"
export OMNISIMPLEMEM_BASELINE_ROOT="${REPO_ROOT}/OmniSimpleMem"
export SAVE_ROOT_PATH="${SMMBENCH_ROOT}/runs"

# OpenAI-compatible VLM gateway (required for API models in constant.API_VLMS).
export MODEL_API_KEY="YOUR_API_KEY"
export MODEL_API_BASE_URL="https://YOUR_ENDPOINT/v1"
# Prefer a model available on your gateway (e.g. gpt-5.4-mini on the memeye proxy).
export MODEL="${MODEL:-gpt-5.4-mini}"

# Smoke defaults: cluster_1 only. Set both to -1 for full benchmark.
export START_CLUSTER_INDEX="${START_CLUSTER_INDEX:-1}"
export END_CLUSTER_INDEX="${END_CLUSTER_INDEX:-1}"
export EVAL_STRATEGY="${EVAL_STRATEGY:-time_sequential_memory}"
export EVAL_ROUNDS="${EVAL_ROUNDS:-1}"

# Embeddings for OmniSimpleMem.
# Full-quality defaults (heavy): BAAI/bge-m3 + BAAI/bge-visualized, dim 1024.
# Smoke-friendly defaults (lighter): MiniLM + OpenVision.
export OMNI_EMBEDDING_MODEL="${OMNI_EMBEDDING_MODEL:-all-MiniLM-L6-v2}"
export OMNI_EMBEDDING_DIM="${OMNI_EMBEDDING_DIM:-384}"
export OMNI_VISUAL_EMBEDDING_MODEL="${OMNI_VISUAL_EMBEDDING_MODEL:-UCSC-VLAA/openvision-vit-large-patch14-224}"
export OMNI_VISUAL_EMBEDDING_DIM="${OMNI_VISUAL_EMBEDDING_DIM:-768}"
export OMNI_TOP_K="${OMNI_TOP_K:-20}"
export OMNI_CHUNK_TURNS="${OMNI_CHUNK_TURNS:-20}"
export OMNI_CHUNK_MAX_CHARS="${OMNI_CHUNK_MAX_CHARS:-6000}"
export OMNI_CHUNK_MAX_IMAGES="${OMNI_CHUNK_MAX_IMAGES:-8}"
# Set to 1 to reuse checkpoint and only re-run QA (no caption/embedding ingest).
export OMNI_SKIP_INGEST="${OMNI_SKIP_INGEST:-0}"
